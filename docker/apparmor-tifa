#include <tunables/global>
profile tifa-runner flags=(attach_disconnected,mediate_deleted) {
  #include <abstractions/base>
  network deny,
  capability,
  deny capability sys_admin,
  deny capability sys_ptrace,
  / r,
  /usr/** rix,
  /lib/** rix,
  /workspace/** rwk,
  /tmp/** rw,
  deny /proc/sys/** w,
  deny /sys/** w,
}
